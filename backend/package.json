{
  "name": "chrmo-meycauayan-backend",
  "version": "1.0.0",
  "description": "Backend for NEBR application",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node --import @swc-node/register/esm-register index.ts",
    "dev": "nodemon --exec \"node --import @swc-node/register/esm-register\" index.ts",
    "seed": "node db/seed.js",
    "seed:reset": "node db/seed.js --reset",
    "clear-applicants": "node --import @swc-node/register/esm-register scripts/clear_test_applicants.ts",
    "wipe-data": "node --import @swc-node/register/esm-register scripts/wipe_clean.ts",
    "db:reset": "node --import @swc-node/register/esm-register scripts/reset_db.ts",
    "db:generate": "tsx node_modules/drizzle-kit/bin.cjs generate",
    "db:push": "tsx node_modules/drizzle-kit/bin.cjs push",
    "db:migrate": "tsx node_modules/drizzle-kit/bin.cjs migrate",
    "db:studio": "drizzle-kit studio",
    "clean": "rimraf node_modules package-lock.json dist && npm install",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "build": "swc src -d dist",
    "diagnose-pds": "node --import @swc-node/register/esm-register scripts/diagnose-pds-display-v2.ts",
    "test-pds-parser": "node --import @swc-node/register/esm-register scripts/test-pds-parser.ts",
    "dump-excel": "node --import @swc-node/register/esm-register scripts/dump-excel-cells.ts",
    "map-excel": "node --import @swc-node/register/esm-register scripts/comprehensive-excel-map.ts"
  },
  "dependencies": {
    "@faker-js/faker": "^10.2.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/ws": "^8.18.1",
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "drizzle-orm": "^0.45.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "form-data": "^4.0.5",
    "google-auth-library": "^10.5.0",
    "googleapis": "^170.0.0",
    "helmet": "^7.1.0",
    "ics": "^3.8.1",
    "imap": "^0.8.19",
    "jsonwebtoken": "^9.0.2",
    "mailparser": "^3.9.1",
    "moment": "^2.30.1",
    "multer": "^2.0.2",
    "mysql2": "^3.6.5",
    "node-cache": "^5.1.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.11",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.17.2",
    "serialport": "^13.0.0",
    "ws": "^8.19.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/imap": "^0.8.43",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mailparser": "^3.4.6",
    "@types/moment": "^2.11.29",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.2.2",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.4",
    "@types/pdfkit": "^0.17.4",
    "@types/serialport": "^8.0.5",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "drizzle-kit": "^0.31.9",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^15.15.0",
    "kysely": "^0.28.11",
    "nodemon": "^3.1.11",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.17"
  }
}
