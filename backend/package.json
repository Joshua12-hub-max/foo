{
  "name": "nebr-backend",
  "version": "1.0.0",
  "description": "Backend for NEBR application",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node --import @swc-node/register/esm-register server.ts",
    "dev": "nodemon --exec 'node --import @swc-node/register/esm-register' server.ts",
    "seed": "node db/seed.js",
    "seed:reset": "node db/seed.js --reset",
    "clean": "rimraf node_modules package-lock.json dist && npm install",
    "type-check": "tsc --noEmit",
    "build": "swc src -d dist"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "google-auth-library": "^10.5.0",
    "googleapis": "^170.0.0",
    "helmet": "^7.1.0",
    "ics": "^3.8.1",
    "imap": "^0.8.19",
    "jsonwebtoken": "^9.0.2",
    "mailparser": "^3.9.1",
    "multer": "^2.0.2",
    "mysql2": "^3.6.5",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.11",
    "pdfkit": "^0.17.2",
    "serialport": "^13.0.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/imap": "^0.8.43",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mailparser": "^3.4.6",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.0.3",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.4",
    "@types/pdfkit": "^0.17.4",
    "nodemon": "^3.1.11",
    "typescript": "^5.9.3"
  }
}
